{% comment %}
  StellarLight Magic - Cart Drawer Snippet
  Slide-out cart drawer for quick cart management
{% endcomment %}

<div class="cart-drawer" id="CartDrawer" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="CartDrawerTitle">
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title" id="CartDrawerTitle">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      Your Cart
    </h2>
    <button type="button" class="cart-drawer__close" aria-label="Close cart">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="cart-drawer__content">
    {% if cart.item_count > 0 %}
      <div class="cart-drawer__items">
        {% for item in cart.items %}
          <div class="cart-drawer__item" data-key="{{ item.key }}" data-line="{{ forloop.index }}">
            <div class="cart-drawer__item-image">
              <a href="{{ item.url }}">
                {% if item.image %}
                  <img src="{{ item.image | img_url: '120x120' }}"
                       srcset="{{ item.image | img_url: '120x120' }} 1x, {{ item.image | img_url: '240x240' }} 2x"
                       alt="{{ item.title | escape }}"
                       loading="lazy"
                       width="80"
                       height="80">
                {% else %}
                  <div class="cart-drawer__item-placeholder">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21,15 16,10 5,21"/>
                    </svg>
                  </div>
                {% endif %}
              </a>
            </div>

            <div class="cart-drawer__item-details">
              <div class="cart-drawer__item-header">
                <a href="{{ item.url }}" class="cart-drawer__item-title">
                  {{ item.product.title }}
                </a>
                <button type="button"
                        class="cart-drawer__item-remove"
                        data-key="{{ item.key }}"
                        aria-label="Remove {{ item.title | escape }} from cart">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="3,6 5,6 21,6"/>
                    <path d="M19,6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3,0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                  </svg>
                </button>
              </div>

              {% if item.variant.title != 'Default Title' and item.variant.title != blank %}
                <p class="cart-drawer__item-variant">{{ item.variant.title }}</p>
              {% endif %}

              <div class="cart-drawer__item-footer">
                <div class="cart-drawer__item-quantity quantity-selector quantity-selector--sm">
                  <button type="button"
                          class="quantity-selector__btn quantity-selector__btn--minus"
                          data-key="{{ item.key }}"
                          data-action="decrease"
                          aria-label="Decrease quantity">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                  </button>
                  <input type="number"
                         name="updates[]"
                         value="{{ item.quantity }}"
                         min="0"
                         data-key="{{ item.key }}"
                         data-line="{{ forloop.index }}"
                         class="quantity-selector__input"
                         aria-label="Quantity for {{ item.title | escape }}">
                  <button type="button"
                          class="quantity-selector__btn quantity-selector__btn--plus"
                          data-key="{{ item.key }}"
                          data-action="increase"
                          aria-label="Increase quantity">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="12" y1="5" x2="12" y2="19"/>
                      <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                  </button>
                </div>

                <div class="cart-drawer__item-price">
                  {% if item.original_line_price > item.line_price %}
                    <span class="cart-drawer__item-price-original">{{ item.original_line_price | money }}</span>
                  {% endif %}
                  <span class="cart-drawer__item-price-current">{{ item.line_price | money }}</span>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Upsell/Cross-sell Section -->
      {% if settings.show_cart_upsell %}
        <div class="cart-drawer__upsell">
          <p class="cart-drawer__upsell-title">You may also like</p>
          <div class="cart-drawer__upsell-grid">
            {% for product in collections.all.products limit:2 %}
              {% unless cart.items contains product.id %}
                <div class="cart-drawer__upsell-item">
                  <a href="{{ product.url }}" class="cart-drawer__upsell-link">
                    <img src="{{ product.featured_image | img_url: '100x100' }}"
                         alt="{{ product.title | escape }}"
                         loading="lazy"
                         width="60"
                         height="60">
                    <div class="cart-drawer__upsell-info">
                      <span class="cart-drawer__upsell-name">{{ product.title | truncate: 30 }}</span>
                      <span class="cart-drawer__upsell-price">{{ product.price | money }}</span>
                    </div>
                  </a>
                </div>
              {% endunless %}
            {% endfor %}
          </div>
        </div>
      {% endif %}

    {% else %}
      <div class="cart-drawer__empty">
        <div class="cart-drawer__empty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
        </div>
        <p class="cart-drawer__empty-text">Your cart is empty</p>
        <p class="cart-drawer__empty-subtext">Looks like you haven't added anything to your cart yet.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
          Start Shopping
        </a>
      </div>
    {% endif %}
  </div>

  {% if cart.item_count > 0 %}
    <div class="cart-drawer__footer">
      <!-- Discount Code -->
      <div class="cart-drawer__discount">
        <form action="/cart" method="post" id="CartDrawerDiscountForm">
          <div class="cart-drawer__discount-input-group">
            <input type="text"
                   name="discount"
                   class="form-input cart-drawer__discount-input"
                   placeholder="Discount code"
                   aria-label="Discount code">
            <button type="submit" class="btn btn--sm btn--outline cart-drawer__discount-btn">
              Apply
            </button>
          </div>
        </form>
      </div>

      <!-- Subtotal -->
      <div class="cart-drawer__subtotal">
        <span class="cart-drawer__subtotal-label">Subtotal</span>
        <span class="cart-drawer__subtotal-value">{{ cart.total_price | money }}</span>
      </div>

      {% if cart.total_discounts > 0 %}
        <div class="cart-drawer__discounts">
          <span class="cart-drawer__discounts-label">Savings</span>
          <span class="cart-drawer__discounts-value">-{{ cart.total_discounts | money }}</span>
        </div>
      {% endif %}

      <p class="cart-drawer__note">
        Shipping & taxes calculated at checkout
      </p>

      <!-- Checkout Button -->
      <form action="{{ routes.cart_url }}" method="post" id="CartDrawerForm">
        <button type="submit"
                name="checkout"
                class="btn btn--primary btn--full btn--lg cart-drawer__checkout">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Checkout
        </button>
      </form>

      <a href="{{ routes.cart_url }}" class="cart-drawer__view-cart">
        View Full Cart
      </a>

      <!-- Trust Badges -->
      <div class="cart-drawer__trust">
        <div class="cart-drawer__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <span>Secure checkout</span>
        </div>
        <div class="cart-drawer__trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20,6 9,17 4,12"/>
          </svg>
          <span>Free returns</span>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<style>
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 400px;
    max-width: 100vw;
    height: 100%;
    background: var(--color-surface-alt);
    z-index: 3000;
    transform: translateX(100%);
    transition: transform var(--transition-base);
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
  }

  .cart-drawer[aria-hidden="false"] {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .cart-drawer__title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 18px;
    font-weight: 500;
    margin: 0;
  }

  .cart-drawer__title svg {
    color: var(--color-gold);
  }

  .cart-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-secondary);
    border-radius: var(--radius-full);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .cart-drawer__close:hover {
    color: var(--color-gold);
    background: var(--color-gold-light);
  }

  .cart-drawer__content {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-lg);
  }

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-base);
  }

  .cart-drawer__item {
    display: flex;
    gap: var(--space-base);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .cart-drawer__item:last-child {
    border-bottom: none;
  }

  .cart-drawer__item-image {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-surface);
  }

  .cart-drawer__item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-drawer__item-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .cart-drawer__item-details {
    flex: 1;
    min-width: 0;
  }

  .cart-drawer__item-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .cart-drawer__item-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-primary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cart-drawer__item-title:hover {
    color: var(--color-gold);
  }

  .cart-drawer__item-remove {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .cart-drawer__item-remove:hover {
    color: var(--color-error);
    background: rgba(198, 40, 40, 0.1);
  }

  .cart-drawer__item-variant {
    font-size: 12px;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .cart-drawer__item-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .quantity-selector--sm {
    transform: scale(0.9);
    transform-origin: left center;
  }

  .quantity-selector--sm .quantity-selector__input {
    height: 32px;
    width: 48px;
  }

  .quantity-selector--sm .quantity-selector__btn {
    width: 32px;
    height: 32px;
  }

  .cart-drawer__item-price {
    text-align: right;
  }

  .cart-drawer__item-price-original {
    display: block;
    font-size: 12px;
    color: var(--color-text-muted);
    text-decoration: line-through;
  }

  .cart-drawer__item-price-current {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-gold);
  }

  /* Empty State */
  .cart-drawer__empty {
    text-align: center;
    padding: var(--space-3xl) var(--space-lg);
  }

  .cart-drawer__empty-icon {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .cart-drawer__empty-text {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: var(--space-sm);
  }

  .cart-drawer__empty-subtext {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
  }

  /* Upsell Section */
  .cart-drawer__upsell {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .cart-drawer__upsell-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-base);
  }

  .cart-drawer__upsell-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .cart-drawer__upsell-item {
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-fast);
  }

  .cart-drawer__upsell-item:hover {
    background: var(--color-gold-light);
  }

  .cart-drawer__upsell-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm);
  }

  .cart-drawer__upsell-link img {
    width: 50px;
    height: 50px;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }

  .cart-drawer__upsell-info {
    flex: 1;
    min-width: 0;
  }

  .cart-drawer__upsell-name {
    display: block;
    font-size: 13px;
    color: var(--color-text-primary);
    margin-bottom: 2px;
  }

  .cart-drawer__upsell-price {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-gold);
  }

  /* Footer */
  .cart-drawer__footer {
    padding: var(--space-lg);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    flex-shrink: 0;
  }

  .cart-drawer__discount {
    margin-bottom: var(--space-base);
  }

  .cart-drawer__discount-input-group {
    display: flex;
    gap: var(--space-xs);
  }

  .cart-drawer__discount-input {
    flex: 1;
    min-width: 0;
    padding: var(--space-sm) var(--space-base);
    font-size: 13px;
  }

  .cart-drawer__discount-btn {
    flex-shrink: 0;
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .cart-drawer__subtotal-label {
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .cart-drawer__subtotal-value {
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 500;
    color: var(--color-gold);
  }

  .cart-drawer__discounts {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .cart-drawer__discounts-label {
    font-size: 13px;
    color: var(--color-success);
  }

  .cart-drawer__discounts-value {
    font-size: 13px;
    color: var(--color-success);
  }

  .cart-drawer__note {
    font-size: 12px;
    color: var(--color-text-muted);
    text-align: center;
    margin-bottom: var(--space-base);
  }

  .cart-drawer__checkout {
    margin-bottom: var(--space-sm);
  }

  .cart-drawer__view-cart {
    display: block;
    text-align: center;
    font-size: 14px;
    color: var(--color-text-secondary);
    padding: var(--space-sm) 0;
    transition: color var(--transition-fast);
  }

  .cart-drawer__view-cart:hover {
    color: var(--color-gold);
  }

  .cart-drawer__trust {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
    margin-top: var(--space-base);
    padding-top: var(--space-base);
    border-top: 1px solid var(--color-border-subtle);
  }

  .cart-drawer__trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .cart-drawer__trust-item svg {
    color: var(--color-success);
  }

  /* Responsive */
  @media (max-width: 480px) {
    .cart-drawer {
      width: 100%;
    }

    .cart-drawer__item-image {
      width: 70px;
      height: 70px;
    }
  }
</style>

<script>
  // Cart drawer item quantity updates
  document.addEventListener('click', async function(e) {
    const target = e.target.closest('.cart-drawer__item-remove, .quantity-selector__btn');
    if (!target) return;

    const cartDrawer = document.getElementById('CartDrawer');
    if (!cartDrawer) return;

    const key = target.dataset.key;
    const action = target.dataset.action;

    if (!key) return;

    // Get current quantity
    const input = cartDrawer.querySelector(`input[data-key="${key}"]`);
    if (!input) return;

    let quantity = parseInt(input.value) || 0;

    if (action === 'increase') {
      quantity++;
    } else if (action === 'decrease') {
      quantity = Math.max(0, quantity - 1);
    } else {
      // Remove button
      quantity = 0;
    }

    // Update cart via AJAX
    try {
      const response = await fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          id: key,
          quantity: quantity
        })
      });

      if (!response.ok) throw new Error('Failed to update cart');

      // Trigger cart update event
      document.dispatchEvent(new CustomEvent('cart:updated'));

      // Refresh the page drawer content
      if (window.StellarLight && window.StellarLight.Cart) {
        await window.StellarLight.Cart.updateCartCount();
      }
    } catch (error) {
      console.error('Error updating cart:', error);
      if (window.StellarLight && window.StellarLight.Toast) {
        window.StellarLight.Toast.show('Failed to update cart', 'error');
      }
    }
  });
</script>
