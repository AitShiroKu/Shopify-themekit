{% comment %}
  StellarLight Magic — Product Card (redesigned)
  Params:
    - product (required)
    - show_vendor (default: true)
    - show_quick_add (default: true)
    - show_secondary_image (default: true)
{% endcomment %}

{% liquid
  assign show_vendor = show_vendor | default: true
  assign show_quick_add = show_quick_add | default: true
  assign show_secondary_image = show_secondary_image | default: true
  assign first_variant = product.selected_or_first_available_variant
  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
    assign save_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
  endif
%}

<article class="pcard{% unless product.available %} pcard--soldout{% endunless %}"
         data-product-id="{{ product.id }}"
         data-variant-id="{{ first_variant.id }}"
         itemscope itemtype="http://schema.org/Product">

  <div class="pcard__media">
    <a href="{{ product.url | within: collection }}" class="pcard__media-link" aria-label="{{ product.title | escape }}">
      {% if product.featured_image %}
        <img class="pcard__img pcard__img--primary"
             src="{{ product.featured_image | img_url: '600x600' }}"
             srcset="{{ product.featured_image | img_url: '300x300' }} 300w,
                     {{ product.featured_image | img_url: '600x600' }} 600w,
                     {{ product.featured_image | img_url: '900x900' }} 900w"
             sizes="(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 50vw"
             alt="{{ product.featured_image.alt | default: product.title | escape }}"
             width="600" height="600"
             loading="lazy"
             itemprop="image">

        {% if show_secondary_image and product.images.size > 1 %}
          <img class="pcard__img pcard__img--alt"
               src="{{ product.images[1] | img_url: '600x600' }}"
               srcset="{{ product.images[1] | img_url: '300x300' }} 300w,
                       {{ product.images[1] | img_url: '600x600' }} 600w,
                       {{ product.images[1] | img_url: '900x900' }} 900w"
               sizes="(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 50vw"
               alt=""
               width="600" height="600"
               loading="lazy"
               aria-hidden="true">
        {% endif %}
      {% else %}
        <div class="pcard__placeholder" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21,15 16,10 5,21"/>
          </svg>
        </div>
      {% endif %}
    </a>

    <div class="pcard__flags">
      {% unless product.available %}
        <span class="pcard__flag pcard__flag--soldout">Sold out</span>
      {% else %}
        {% if on_sale %}<span class="pcard__flag pcard__flag--sale">−{{ save_pct }}%</span>{% endif %}
        {% for tag in product.tags %}
          {% if tag == 'new' %}<span class="pcard__flag pcard__flag--new">New</span>{% break %}
          {% elsif tag == 'best-seller' %}<span class="pcard__flag pcard__flag--best">Best Seller</span>{% break %}
          {% endif %}
        {% endfor %}
      {% endunless %}
    </div>

    <button type="button" class="pcard__wishlist" aria-label="Save {{ product.title | escape }} to wishlist" data-wishlist>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8l1 1.1L12 21.2l7.8-7.7 1-1.1a5.5 5.5 0 0 0 0-7.8z"/>
      </svg>
    </button>

    {% if show_quick_add and product.available %}
      <button type="button" class="pcard__quick" data-variant-id="{{ first_variant.id }}" aria-label="Quick add {{ product.title | escape }}">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        <span>Quick add</span>
      </button>
    {% endif %}
  </div>

  <div class="pcard__body">
    {% if show_vendor and product.vendor != blank %}
      <p class="pcard__vendor">{{ product.vendor }}</p>
    {% endif %}

    <h3 class="pcard__title" itemprop="name">
      <a href="{{ product.url | within: collection }}">{{ product.title }}</a>
    </h3>

    <div class="pcard__price-row" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
      <meta itemprop="priceCurrency" content="{{ shop.currency }}">
      <meta itemprop="price" content="{{ product.price | money_without_currency }}">
      <link itemprop="availability" href="{% if product.available %}http://schema.org/InStock{% else %}http://schema.org/OutOfStock{% endif %}">

      <span class="pcard__price">{{ product.price | money }}</span>
      {% if on_sale %}<span class="pcard__price-compare">{{ product.compare_at_price | money }}</span>{% endif %}
    </div>

    {% if product.has_only_default_variant == false %}
      {% assign has_color = false %}
      {% for option in product.options %}
        {% if option == 'Color' or option == 'Colour' %}{% assign has_color = true %}{% assign color_index = forloop.index0 %}{% endif %}
      {% endfor %}

      {% if has_color %}
        <ul class="pcard__swatches" aria-label="Available colours">
          {% assign seen = '' %}
          {% for variant in product.variants limit: 5 %}
            {% assign color_val = variant.options[color_index] %}
            {% unless seen contains color_val %}
              <li class="pcard__swatch" style="--swatch: {{ color_val | handle | replace: '-', '' }};" title="{{ color_val }}"></li>
              {% assign seen = seen | append: color_val | append: '|' %}
            {% endunless %}
          {% endfor %}
          {% if product.variants.size > 5 %}
            <li class="pcard__swatch-more">+{{ product.variants.size | minus: 5 }}</li>
          {% endif %}
        </ul>
      {% endif %}
    {% endif %}
  </div>
</article>
