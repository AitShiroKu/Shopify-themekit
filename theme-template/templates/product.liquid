{% comment %}
  StellarLight Magic — Product Template (redesigned)
  Premium PDP: vertical thumbs · 60/40 gallery + sticky buy panel · trust row · highlight grid · accordion details
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_image = current_variant.featured_image | default: product.featured_image %}
{% assign savings_amt = current_variant.compare_at_price | minus: current_variant.price %}
{% assign savings_pct = 0 %}
{% if current_variant.compare_at_price > current_variant.price %}
  {% assign savings_pct = savings_amt | times: 100 | divided_by: current_variant.compare_at_price %}
{% endif %}

<section class="pdp" itemscope itemtype="http://schema.org/Product">
  <div class="container">

    <!-- Breadcrumbs -->
    <nav class="pdp__crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span aria-hidden="true">/</span>
      {% if collection %}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span aria-hidden="true">/</span>
      {% elsif product.type != blank %}
        <a href="{{ routes.root_url }}collections/all">Shop</a>
        <span aria-hidden="true">/</span>
      {% endif %}
      <span class="pdp__crumbs-current" aria-current="page">{{ product.title }}</span>
    </nav>

    <div class="pdp__layout">

      <!-- ========== GALLERY ========== -->
      <div class="pdp__gallery" data-pdp-gallery>

        <div class="pdp__thumbs" role="tablist" aria-label="Product images">
          {% for image in product.images %}
            <button type="button"
                    class="pdp__thumb {% if image == featured_image %}is-active{% endif %}"
                    data-pdp-thumb
                    data-image="{{ image | img_url: '1200x1200' }}"
                    data-srcset="{{ image | img_url: '600x600' }} 600w, {{ image | img_url: '1200x1200' }} 1200w, {{ image | img_url: '1600x1600' }} 1600w"
                    data-alt="{{ image.alt | default: product.title | escape }}"
                    aria-label="View image {{ forloop.index }} of {{ product.images.size }}"
                    aria-selected="{% if image == featured_image %}true{% else %}false{% endif %}">
              <img src="{{ image | img_url: '160x160' }}"
                   alt=""
                   width="80" height="80"
                   loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            </button>
          {% endfor %}
        </div>

        <figure class="pdp__stage" data-pdp-stage>
          {% if featured_image %}
            <div class="pdp__stage-inner" data-pdp-zoom>
              <img id="ProductPhotoImg"
                   class="pdp__stage-image"
                   src="{{ featured_image | img_url: '1200x1200' }}"
                   srcset="{{ featured_image | img_url: '600x600' }} 600w,
                           {{ featured_image | img_url: '1200x1200' }} 1200w,
                           {{ featured_image | img_url: '1600x1600' }} 1600w"
                   sizes="(min-width: 1024px) 52vw, 100vw"
                   alt="{{ featured_image.alt | default: product.title | escape }}"
                   itemprop="image"
                   loading="eager"
                   fetchpriority="high">
            </div>

            <div class="pdp__stage-flags">
              {% if savings_pct > 0 %}
                <span class="pdp__flag pdp__flag--sale">−{{ savings_pct }}%</span>
              {% endif %}
              {% unless current_variant.available %}
                <span class="pdp__flag pdp__flag--soldout">Sold Out</span>
              {% endunless %}
              {% for tag in product.tags %}
                {% if tag == 'new' %}<span class="pdp__flag pdp__flag--new">New</span>{% break %}{% endif %}
              {% endfor %}
            </div>

            <button class="pdp__stage-nav pdp__stage-nav--prev" type="button" data-pdp-prev aria-label="Previous image">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button class="pdp__stage-nav pdp__stage-nav--next" type="button" data-pdp-next aria-label="Next image">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          {% else %}
            <div class="pdp__stage-placeholder" aria-hidden="true">
              <svg width="72" height="72" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21,15 16,10 5,21"/>
              </svg>
            </div>
          {% endif %}
        </figure>
      </div>

      <!-- ========== PURCHASE PANEL ========== -->
      <aside class="pdp__panel">
        <header class="pdp__head">
          {% if product.vendor != blank %}
            <a class="pdp__vendor" href="{{ routes.root_url }}collections/vendors?q={{ product.vendor | url_encode }}">{{ product.vendor }}</a>
          {% endif %}

          <h1 class="pdp__title" itemprop="name">{{ product.title }}</h1>

          <div class="pdp__meta-row">
            <div class="pdp__rating" aria-label="4.8 out of 5 stars">
              {% for i in (1..5) %}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% endfor %}
              <span class="pdp__rating-text">4.8 · <a href="#pdp-reviews">124 reviews</a></span>
            </div>
          </div>
        </header>

        <div class="pdp__price" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
          <meta itemprop="priceCurrency" content="{{ shop.currency }}">
          <meta itemprop="price" content="{{ current_variant.price | money_without_currency }}">
          <link itemprop="availability" href="{% if current_variant.available %}http://schema.org/InStock{% else %}http://schema.org/OutOfStock{% endif %}">

          <span class="pdp__price-current" id="ProductPrice">{{ current_variant.price | money }}</span>
          {% if current_variant.compare_at_price > current_variant.price %}
            <span class="pdp__price-compare" id="ComparePrice">{{ current_variant.compare_at_price | money }}</span>
            <span class="pdp__price-save">Save {{ savings_amt | money }}</span>
          {% endif %}
        </div>

        {% if product.description != blank %}
          <p class="pdp__lede">{{ product.description | strip_html | truncate: 180 }}</p>
        {% endif %}

        <!-- ========== FORM ========== -->
        <form action="/cart/add" method="post" enctype="multipart/form-data" id="AddToCartForm" class="pdp__form">
          <input type="hidden" name="id" value="{{ current_variant.id }}" id="ProductVariantId">

          <script type="application/json" id="ProductVariants">
            {{ product.variants | json }}
          </script>

          {% unless product.has_only_default_variant %}
            <div class="pdp__options">
              {% for option in product.options_with_values %}
                {% assign is_color = false %}
                {% if option.name == 'Color' or option.name == 'Colour' %}{% assign is_color = true %}{% endif %}

                <fieldset class="pdp__option" data-option-name="{{ option.name | escape }}">
                  <legend class="pdp__option-label">
                    <span>{{ option.name }}</span>
                    <span class="pdp__option-value" data-option-selected>
                      {%- for value in option.values -%}
                        {%- if current_variant.options contains value -%}{{ value }}{%- endif -%}
                      {%- endfor -%}
                    </span>
                  </legend>

                  <div class="pdp__option-values {% if is_color %}pdp__option-values--swatch{% endif %}">
                    {% for value in option.values %}
                      {% assign variant = product.variants | where: option.name, value | first %}
                      {% assign checked = false %}
                      {% if current_variant.options contains value %}{% assign checked = true %}{% endif %}

                      <button type="button"
                              class="{% if is_color %}pdp__swatch{% else %}pdp__pill{% endif %}{% if checked %} is-active{% endif %}{% unless variant.available %} is-unavailable{% endunless %}"
                              data-option-value="{{ value | escape }}"
                              {% if is_color %}style="--swatch: {{ value | handle | replace: '-', '' }};"{% endif %}
                              {% unless variant.available %}aria-disabled="true"{% endunless %}>
                        {% if is_color %}
                          <span class="pdp__swatch-dot" aria-hidden="true"></span>
                          <span class="sr-only">{{ value }}</span>
                        {% else %}
                          {{ value }}
                        {% endif %}
                      </button>
                    {% endfor %}
                  </div>

                  <select name="options[{{ option.name }}]" class="hidden" aria-hidden="true" tabindex="-1">
                    {% for value in option.values %}
                      <option value="{{ value | escape }}" {% if current_variant.options contains value %}selected{% endif %}>{{ value }}</option>
                    {% endfor %}
                  </select>
                </fieldset>
              {% endfor %}
            </div>
          {% endunless %}

          <div class="pdp__buy">
            <div class="pdp__qty quantity-selector">
              <button type="button" class="quantity-selector__btn quantity-selector__btn--minus" aria-label="Decrease quantity">−</button>
              <input type="number" name="quantity" value="1" min="1" max="999" class="quantity-selector__input" aria-label="Quantity">
              <button type="button" class="quantity-selector__btn quantity-selector__btn--plus" aria-label="Increase quantity">+</button>
            </div>

            <button type="submit" name="add" id="AddToCart"
                    class="pdp__add btn btn--primary btn--lg btn--full"
                    {% unless current_variant.available %}disabled{% endunless %}>
              <span class="pdp__add-text">
                {% if current_variant.available %}Add to Cart · {{ current_variant.price | money }}{% else %}Sold Out{% endif %}
              </span>
            </button>

            {% if current_variant.available %}
              <button type="button" class="pdp__wishlist" aria-label="Save to wishlist" data-wishlist>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8l1 1.1L12 21.2l7.8-7.7 1-1.1a5.5 5.5 0 0 0 0-7.8z"/>
                </svg>
              </button>
            {% endif %}
          </div>

          {% if current_variant.sku != blank %}
            <p class="pdp__sku">SKU <span itemprop="sku">{{ current_variant.sku }}</span></p>
          {% endif %}
        </form>

        <!-- ========== TRUST ROW ========== -->
        <ul class="pdp__trust" role="list">
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <div>
              <strong>Free shipping</strong>
              <span>On orders over $50</span>
            </div>
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.5 15a9 9 0 1 0 2.1-9.4L1 10"/></svg>
            <div>
              <strong>30-day returns</strong>
              <span>Easy, no-fuss refunds</span>
            </div>
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            <div>
              <strong>Secure checkout</strong>
              <span>256-bit SSL protection</span>
            </div>
          </li>
        </ul>

        <!-- ========== HIGHLIGHTS ========== -->
        {% if product.metafields.custom.highlights or product.tags contains 'highlight-handmade' or product.tags contains 'highlight-sustainable' %}
          <section class="pdp__highlights" aria-label="Product highlights">
            <h2 class="pdp__section-head">The Details</h2>
            <ul class="pdp__highlight-grid">
              {% if product.tags contains 'highlight-handmade' %}
                <li><span class="pdp__highlight-tick">✦</span><div><strong>Handmade</strong><span>Crafted by artisans</span></div></li>
              {% endif %}
              {% if product.tags contains 'highlight-sustainable' %}
                <li><span class="pdp__highlight-tick">✦</span><div><strong>Sustainable</strong><span>Responsibly sourced</span></div></li>
              {% endif %}
              <li><span class="pdp__highlight-tick">✦</span><div><strong>Premium quality</strong><span>Built to last</span></div></li>
              <li><span class="pdp__highlight-tick">✦</span><div><strong>Signature design</strong><span>Exclusively ours</span></div></li>
            </ul>
          </section>
        {% endif %}

        <!-- ========== ACCORDION ========== -->
        <div class="pdp__accordion" role="region" aria-label="Product information">
          <details class="pdp__acc-item" open>
            <summary class="pdp__acc-head">
              <span>Full description</span>
              <svg class="pdp__acc-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="pdp__acc-body rte">
              {{ product.description }}
            </div>
          </details>

          <details class="pdp__acc-item">
            <summary class="pdp__acc-head">
              <span>Details &amp; materials</span>
              <svg class="pdp__acc-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="pdp__acc-body rte">
              <dl class="pdp__spec">
                {% if product.type != blank %}<dt>Type</dt><dd>{{ product.type }}</dd>{% endif %}
                {% if product.vendor != blank %}<dt>Brand</dt><dd>{{ product.vendor }}</dd>{% endif %}
                {% if current_variant.sku != blank %}<dt>SKU</dt><dd>{{ current_variant.sku }}</dd>{% endif %}
                {% if current_variant.weight > 0 %}<dt>Weight</dt><dd>{{ current_variant.weight | weight_with_unit }}</dd>{% endif %}
                <dt>Care</dt><dd>See item tag for instructions</dd>
              </dl>
            </div>
          </details>

          <details class="pdp__acc-item">
            <summary class="pdp__acc-head">
              <span>Shipping &amp; returns</span>
              <svg class="pdp__acc-chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="pdp__acc-body rte">
              <p>Orders ship within 1–2 business days from our studio.</p>
              <ul>
                <li><strong>Standard</strong> — 5–7 business days</li>
                <li><strong>Express</strong> — 2–3 business days</li>
                <li><strong>Free shipping</strong> — On orders over $50</li>
              </ul>
              <p>Returns accepted within 30 days of delivery in original condition.</p>
            </div>
          </details>
        </div>

        <!-- Share -->
        <div class="pdp__share">
          <span>Share</span>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ product.url | absolute_url }}" target="_blank" rel="noopener" aria-label="Share on Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://twitter.com/intent/tweet?url={{ product.url | absolute_url }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zM17.083 19.77h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://pinterest.com/pin/create/button/?url={{ product.url | absolute_url }}&media={{ featured_image | img_url: 'large' }}&description={{ product.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Pinterest">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.16 9.42 7.63 11.17-.1-.95-.2-2.41.04-3.44.22-.94 1.41-5.97 1.41-5.97s-.36-.72-.36-1.78c0-1.67.97-2.92 2.17-2.92 1.02 0 1.52.77 1.52 1.69 0 1.03-.66 2.57-1 4-.28 1.2.6 2.17 1.78 2.17 2.13 0 3.77-2.25 3.77-5.5 0-2.87-2.06-4.88-5.01-4.88-3.41 0-5.42 2.56-5.42 5.21 0 1.03.4 2.14.89 2.74.1.12.11.22.08.34l-.33 1.36c-.05.22-.17.27-.4.16-1.5-.7-2.44-2.89-2.44-4.65 0-3.79 2.75-7.27 7.93-7.27 4.16 0 7.4 2.97 7.4 6.93 0 4.14-2.61 7.47-6.23 7.47-1.22 0-2.36-.63-2.75-1.38l-.75 2.86c-.27 1.04-1 2.35-1.49 3.15C9.57 23.81 10.76 24 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0z"/></svg>
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- ========== RELATED ========== -->
<section class="section section--compact" aria-labelledby="related-heading">
  <div class="container">
    <header class="section__header section__header--center">
      <span class="section__overline">Discover more</span>
      <h2 class="section__title h2" id="related-heading">You may also like</h2>
    </header>

    <div class="product-grid">
      {% assign related_shown = 0 %}
      {% for related in collection.products limit: 8 %}
        {% unless related.id == product.id %}
          {% if related_shown < 4 %}
            {% render 'product-card', product: related %}
            {% assign related_shown = related_shown | plus: 1 %}
          {% endif %}
        {% endunless %}
      {% endfor %}
      {% if related_shown == 0 %}
        {% for related in collections.all.products limit: 8 %}
          {% unless related.id == product.id %}
            {% if related_shown < 4 %}
              {% render 'product-card', product: related %}
              {% assign related_shown = related_shown | plus: 1 %}
            {% endif %}
          {% endunless %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<!-- Reviews anchor -->
<div id="pdp-reviews"></div>

<script>
  (function() {
    var gallery = document.querySelector('[data-pdp-gallery]');
    if (!gallery) return;
    var stage = gallery.querySelector('[data-pdp-stage]');
    var img = document.getElementById('ProductPhotoImg');
    var thumbs = Array.prototype.slice.call(gallery.querySelectorAll('[data-pdp-thumb]'));
    var zoom = gallery.querySelector('[data-pdp-zoom]');
    var idx = Math.max(0, thumbs.findIndex(function(t) { return t.classList.contains('is-active'); }));

    function select(i) {
      if (!thumbs.length || !img) return;
      idx = (i + thumbs.length) % thumbs.length;
      thumbs.forEach(function(t, j) {
        t.classList.toggle('is-active', j === idx);
        t.setAttribute('aria-selected', j === idx ? 'true' : 'false');
      });
      var t = thumbs[idx];
      img.src = t.dataset.image;
      if (t.dataset.srcset) img.srcset = t.dataset.srcset;
      if (t.dataset.alt) img.alt = t.dataset.alt;
    }

    thumbs.forEach(function(t, j) {
      t.addEventListener('click', function(e) { e.preventDefault(); select(j); });
    });

    var prev = gallery.querySelector('[data-pdp-prev]');
    var next = gallery.querySelector('[data-pdp-next]');
    if (prev) prev.addEventListener('click', function() { select(idx - 1); });
    if (next) next.addEventListener('click', function() { select(idx + 1); });

    // Hover zoom (desktop only)
    if (zoom && img && window.matchMedia('(hover: hover) and (min-width: 1024px)').matches) {
      zoom.addEventListener('mousemove', function(e) {
        var r = zoom.getBoundingClientRect();
        var x = ((e.clientX - r.left) / r.width) * 100;
        var y = ((e.clientY - r.top) / r.height) * 100;
        img.style.transformOrigin = x + '% ' + y + '%';
      });
      zoom.addEventListener('mouseenter', function() { zoom.classList.add('is-zoomed'); });
      zoom.addEventListener('mouseleave', function() {
        zoom.classList.remove('is-zoomed');
        img.style.transformOrigin = 'center';
      });
    }

    // Option → variant sync + price/image update
    var form = document.getElementById('AddToCartForm');
    var variantsEl = document.getElementById('ProductVariants');
    if (!form || !variantsEl) return;
    var variants;
    try { variants = JSON.parse(variantsEl.textContent); } catch (e) { return; }
    var optionGroups = form.querySelectorAll('.pdp__option');
    var hiddenId = document.getElementById('ProductVariantId');
    var priceEl = document.getElementById('ProductPrice');
    var compareEl = document.getElementById('ComparePrice');
    var addBtn = document.getElementById('AddToCart');
    var addText = addBtn && addBtn.querySelector('.pdp__add-text');

    function money(cents) {
      return (cents / 100).toLocaleString(undefined, { style: 'currency', currency: {{ shop.currency | json }} });
    }

    function currentOptions() {
      var values = [];
      optionGroups.forEach(function(group) {
        var active = group.querySelector('.is-active');
        values.push(active ? active.dataset.optionValue : null);
      });
      return values;
    }

    function findVariant(values) {
      return variants.find(function(v) {
        return values.every(function(val, i) { return v.options[i] === val; });
      });
    }

    function sync() {
      var values = currentOptions();
      var v = findVariant(values);
      if (!v) return;
      hiddenId.value = v.id;
      form.querySelectorAll('select[name^="options"]').forEach(function(sel, i) {
        sel.value = values[i];
      });
      if (priceEl) priceEl.textContent = money(v.price);
      if (compareEl) compareEl.style.display = v.compare_at_price > v.price ? '' : 'none';
      if (addText) addText.textContent = v.available ? ('Add to Cart · ' + money(v.price)) : 'Sold Out';
      if (addBtn) addBtn.disabled = !v.available;
      optionGroups.forEach(function(group) {
        var label = group.querySelector('[data-option-selected]');
        var active = group.querySelector('.is-active');
        if (label && active) label.textContent = active.dataset.optionValue;
      });
    }

    optionGroups.forEach(function(group) {
      group.addEventListener('click', function(e) {
        var btn = e.target.closest('.pdp__pill, .pdp__swatch');
        if (!btn || btn.getAttribute('aria-disabled') === 'true') return;
        group.querySelectorAll('.is-active').forEach(function(el) { el.classList.remove('is-active'); });
        btn.classList.add('is-active');
        sync();
      });
    });

    // Wishlist toggle
    var wish = form.querySelector('[data-wishlist]');
    if (wish) {
      wish.addEventListener('click', function() {
        wish.classList.toggle('is-active');
      });
    }
  })();
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "image": {{ product.images | map: 'src' | json }},
  "description": {{ product.description | strip_html | truncate: 300 | json }},
  "sku": {{ current_variant.sku | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | default: shop.name | json }} },
  "offers": {
    "@type": "Offer",
    "url": {{ product.url | absolute_url | json }},
    "priceCurrency": {{ shop.currency | json }},
    "price": {{ current_variant.price | money_without_currency | json }},
    "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "seller": { "@type": "Organization", "name": {{ shop.name | json }} }
  }
}
</script>
