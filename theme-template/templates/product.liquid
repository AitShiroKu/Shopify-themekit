{% comment %}
  StellarLight Magic - Product Template
  Modern product page with gallery, options, and purchase panel
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_image = current_variant.featured_image | default: product.featured_image %}

<div class="product" itemscope itemtype="http://schema.org/Product">
  <div class="container">
    <div class="product__container">
      <!-- Product Gallery -->
      <div class="product__gallery">
        <div class="product__main-image" itemprop="image">
          {% if featured_image %}
            <img src="{{ featured_image | img_url: '800x800' }}"
                 srcset="{{ featured_image | img_url: '400x400' }} 400w,
                         {{ featured_image | img_url: '600x600' }} 600w,
                         {{ featured_image | img_url: '800x800' }} 800w,
                         {{ featured_image | img_url: '1200x1200' }} 1200w"
                 sizes="(min-width: 1024px) 50vw, 100vw"
                 alt="{{ featured_image.alt | default: product.title | escape }}"
                 id="ProductPhotoImg"
                 loading="eager"
                 fetchpriority="high">
          {% else %}
            <div class="product__main-image--placeholder">
              <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21,15 16,10 5,21"/>
              </svg>
            </div>
          {% endif %}
        </div>

        {% if product.images.size > 1 %}
          <div class="product__thumbnails">
            {% for image in product.images %}
              <button class="product__thumbnail {% if image == featured_image %}product__thumbnail--active{% endif %}"
                      data-image="{{ image | img_url: '800x800' }}"
                      data-srcset="{{ image | img_url: '400x400' }} 400w, {{ image | img_url: '800x800' }} 800w, {{ image | img_url: '1200x1200' }} 1200w"
                      aria-label="View image {{ forloop.index }}"
                      type="button">
                <img src="{{ image | img_url: '100x100' }}"
                     alt="{{ image.alt | default: product.title | escape }}"
                     loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Product Info -->
      <div class="product__info">
        {% if product.vendor != blank %}
          <p class="product__brand">{{ product.vendor }}</p>
        {% endif %}

        <h1 class="product__title" itemprop="name">{{ product.title }}</h1>

        <div class="product__price-block" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
          <meta itemprop="priceCurrency" content="{{ shop.currency }}">
          <meta itemprop="price" content="{{ current_variant.price | money_without_currency }}">
          <link itemprop="availability" href="{% if current_variant.available %}http://schema.org/InStock{% else %}http://schema.org/OutOfStock{% endif %}">

          <span class="product__price" id="ProductPrice">
            {{ current_variant.price | money }}
          </span>

          {% if current_variant.compare_at_price > current_variant.price %}
            <span class="product__price-original" id="ComparePrice">
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="badge badge--sale">
              Save {{ current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price }}%
            </span>
          {% endif %}
        </div>

        {% if current_variant.sku != blank %}
          <p class="product__sku">SKU: <span itemprop="sku">{{ current_variant.sku }}</span></p>
        {% endif %}

        {% if product.description != blank %}
          <div class="product__description" itemprop="description">
            {{ product.description | strip_html | truncate: 300 }}
          </div>
        {% endif %}

        <!-- Product Form -->
        <form action="/cart/add" method="post" enctype="multipart/form-data" id="AddToCartForm">
          <input type="hidden" name="id" value="{{ current_variant.id }}" id="ProductVariantId">

          {% comment %} Store variants data for JS {% endcomment %}
          <script type="application/json" id="ProductVariants">
            {{ product.variants | json }}
          </script>

          <!-- Product Options -->
          {% unless product.has_only_default_variant %}
            <div class="product__options">
              {% for option in product.options_with_values %}
                <div class="product__option" data-option-name="{{ option.name | escape }}">
                  <label class="product__option-label">{{ option.name }}</label>
                  <div class="product__option-values">
                    {% for value in option.values %}
                      {% assign is_color = false %}
                      {% if option.name == 'Color' or option.name == 'Colour' %}
                        {% assign is_color = true %}
                      {% endif %}

                      {% assign variant = product.variants | where: option.name, value | first %}
                      {% assign checked = false %}
                      {% if current_variant.options contains value %}
                        {% assign checked = true %}
                      {% endif %}

                      <button type="button"
                              class="{% if is_color %}product__swatch{% else %}product__option-btn{% endif %} {% if checked %}{% if is_color %}product__swatch--active{% else %}product__option-btn--active{% endif %}{% endif %} {% unless variant.available %}product__option-btn--disabled{% endunless %}"
                              data-option-value="{{ value | escape }}"
                              {% if is_color %}
                                style="background-color: {{ value | handle | replace: '-', '' }};"
                              {% endif %}
                              {% unless variant.available %}disabled{% endunless %}>
                        {% unless is_color %}{{ value }}{% endunless %}
                        <span class="sr-only">{{ value }}</span>
                      </button>
                    {% endfor %}
                  </div>

                  <!-- Hidden select for form submission -->
                  <select name="options[{{ option.name }}]" class="hidden" aria-hidden="true">
                    {% for value in option.values %}
                      <option value="{{ value | escape }}" {% if current_variant.options contains value %}selected{% endif %}>{{ value }}</option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            </div>
          {% endunless %}

          <!-- Quantity and Add to Cart -->
          <div class="product__add-to-cart">
            <div class="product__quantity quantity-selector">
              <button type="button" class="quantity-selector__btn quantity-selector__btn--minus" aria-label="Decrease quantity">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </button>
              <input type="number"
                     name="quantity"
                     value="1"
                     min="1"
                     max="999"
                     class="quantity-selector__input"
                     aria-label="Quantity">
              <button type="button" class="quantity-selector__btn quantity-selector__btn--plus" aria-label="Increase quantity">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </button>
            </div>

            <div class="product__actions">
              <button type="submit"
                      name="add"
                      id="AddToCart"
                      class="btn btn--primary btn--full btn--lg"
                      {% unless current_variant.available %}disabled{% endunless %}>
                {% if current_variant.available %}
                  Add to Cart
                {% else %}
                  Sold Out
                {% endif %}
              </button>
            </div>
          </div>
        </form>

        <!-- Product Meta -->
        <div class="product__meta">
          <div class="product__meta-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>Free shipping over $50</span>
          </div>
          <div class="product__meta-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.27,6.96 12,12.01 20.73,6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            <span>Easy returns within 30 days</span>
          </div>
          <div class="product__meta-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span>Secure checkout</span>
          </div>
        </div>

        <!-- Product Tabs -->
        <div class="product__tabs">
          <nav class="product__tabs-nav" role="tablist">
            <button type="button" class="product__tab-btn product__tab-btn--active" data-tab="description" role="tab" aria-selected="true">
              Description
            </button>
            <button type="button" class="product__tab-btn" data-tab="details" role="tab" aria-selected="false">
              Details
            </button>
            <button type="button" class="product__tab-btn" data-tab="shipping" role="tab" aria-selected="false">
              Shipping
            </button>
          </nav>

          <div class="product__tab-content product__tab-content--active" data-tab-content="description" role="tabpanel">
            <div class="rte">
              {{ product.description }}
            </div>
          </div>

          <div class="product__tab-content" data-tab-content="details" role="tabpanel">
            <div class="rte">
              <h4>Product Details</h4>
              <ul>
                <li><strong>Material:</strong> Premium quality</li>
                <li><strong>Dimensions:</strong> See product images</li>
                <li><strong>Care:</strong> Follow care instructions</li>
              </ul>
              {% if product.type != blank %}
                <p><strong>Type:</strong> {{ product.type }}</p>
              {% endif %}
              {% for tag in product.tags %}
                {% if tag contains 'material-' %}
                  <p><strong>Material:</strong> {{ tag | remove: 'material-' }}</p>
                {% endif %}
              {% endfor %}
            </div>
          </div>

          <div class="product__tab-content" data-tab-content="shipping" role="tabpanel">
            <div class="rte">
              <h4>Shipping Information</h4>
              <p>We offer fast and reliable shipping options:</p>
              <ul>
                <li><strong>Standard Shipping:</strong> 5-7 business days</li>
                <li><strong>Express Shipping:</strong> 2-3 business days</li>
                <li><strong>Free Shipping:</strong> On orders over $50</li>
              </ul>
              <p>All orders are processed within 1-2 business days. You'll receive a tracking number once your order ships.</p>
            </div>
          </div>
        </div>

        <!-- Social Share -->
        <div class="product__share">
          <span class="product__share-label">Share:</span>
          <div class="product__share-buttons">
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ product.url | absolute_url }}"
               class="product__share-btn"
               target="_blank"
               rel="noopener noreferrer"
               aria-label="Share on Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
            <a href="https://twitter.com/intent/tweet?url={{ product.url | absolute_url }}&text={{ product.title | url_encode }}"
               class="product__share-btn"
               target="_blank"
               rel="noopener noreferrer"
               aria-label="Share on Twitter">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
              </svg>
            </a>
            <a href="https://pinterest.com/pin/create/button/?url={{ product.url | absolute_url }}&media={{ featured_image | img_url: 'large' }}&description={{ product.title | url_encode }}"
               class="product__share-btn"
               target="_blank"
               rel="noopener noreferrer"
               aria-label="Share on Pinterest">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.351-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Related Products Section -->
<section class="section section--compact" aria-labelledby="related-products-heading">
  <div class="container">
    <div class="section__header">
      <span class="section__overline">You May Also Like</span>
      <h2 class="section__title h2" id="related-products-heading">Related Products</h2>
    </div>

    <div class="product-grid">
      {% for product in collection.products limit:4 %}
        {% unless product == product %}
          {% render 'product-card', product: product %}
        {% endunless %}
      {% else %}
        {% for product in collections.all.products limit:4 %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .product__main-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: var(--color-surface);
    color: var(--color-text-muted);
  }

  .product__share {
    display: flex;
    align-items: center;
    gap: var(--space-base);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-xl);
  }

  .product__share-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .product__share-buttons {
    display: flex;
    gap: var(--space-sm);
  }

  .product__share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
  }

  .product__share-btn:hover {
    color: var(--color-gold);
    background: var(--color-gold-light);
  }

  .rte h4 {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    margin-bottom: var(--space-base);
  }

  .rte ul {
    list-style: disc;
    margin-left: var(--space-lg);
    margin-bottom: var(--space-base);
  }

  .rte li {
    margin-bottom: var(--space-xs);
    color: var(--color-text-secondary);
  }

  .rte p {
    color: var(--color-text-secondary);
  }
</style>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "image": {{ product.images | map: 'src' | json }},
  "description": {{ product.description | strip_html | truncate: 300 | json }},
  "sku": {{ current_variant.sku | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | default: shop.name | json }}
  },
  "offers": {
    "@type": "Offer",
    "url": {{ product.url | absolute_url | json }},
    "priceCurrency": {{ shop.currency | json }},
    "price": {{ current_variant.price | money_without_currency | json }},
    "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    }
  }
}
</script>
