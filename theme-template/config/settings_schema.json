  {
    "name": "Theme Mode",
    "settings": [
      {
        "type": "select",
        "id": "default_theme_mode",
        "label": "Default colour mode",
        "options": [
          { "value": "system", "label": "Match system" },
          { "value": "light", "label": "Light" },
          { "value": "dark", "label": "Dark" }
        ],
        "default": "system"
      },
      {
        "type": "checkbox",
        "id": "show_theme_toggle",
        "label": "Show theme toggle in header",
        "default": true
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "zen_maru_gothic_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "m_plus_rounded_1c_n4"
      }
    ]
  },
  {
    "name": "Branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
