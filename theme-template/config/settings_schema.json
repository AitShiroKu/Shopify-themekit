      },
      {
        "type": "text",
        "id": "footer_tagline",
        "label": "Footer tagline",
        "default": "Premium quality products for the modern lifestyle."
      }
    ]
  },
  {
    "name": "Announcement Bar",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_announcement_bar",
        "label": "Show announcement bar",
        "default": false
      },
      {
        "type": "text",
        "id": "announcement_text",
        "label": "Announcement text",
        "default": "Free shipping on orders over $50"
      },
      {
        "type": "url",
        "id": "announcement_link",
        "label": "Announcement link"
      }
    ]
  },
  {
    "name": "Product Page",
    "settings": [
      {
        "type": "checkbox",
        "id": "pdp_show_breadcrumbs",
        "label": "Show breadcrumbs",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "pdp_show_rating",
        "label": "Show rating stars",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "pdp_show_trust_row",
        "label": "Show trust badges (shipping · returns · secure)",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "pdp_show_highlights",
        "label": "Show highlights grid",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "pdp_image_zoom",
        "label": "Enable hover zoom on product image",
        "default": true
      },
      {
        "type": "range",
        "id": "pdp_related_count",
        "label": "Related products count",
        "min": 0,
        "max": 8,
        "step": 2,
        "default": 4
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      {
        "type": "url",
