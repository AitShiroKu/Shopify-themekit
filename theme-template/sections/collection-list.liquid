{% comment %} Collection tiles — uses blocks so merchants can choose which collections to feature. {% endcomment %}

<section class="section" aria-labelledby="collections-heading-{{ section.id }}">
  <div class="container">
    <div class="section__header">
      {% if section.settings.overline != blank %}
        <span class="section__overline">{{ section.settings.overline }}</span>
      {% endif %}
      <h2 class="section__title h2" id="collections-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
    </div>

    <div class="collections-grid">
      {% for block in section.blocks %}
        {% assign col = collections[block.settings.collection] %}
        {% if col != blank %}
          <a href="{{ col.url }}" class="collection-card" {{ block.shopify_attributes }}>
            <div class="collection-card__image">
              {% if col.image %}
                <img src="{{ col.image | img_url: '600x400' }}"
                     srcset="{{ col.image | img_url: '300x200' }} 300w, {{ col.image | img_url: '600x400' }} 600w"
                     sizes="(min-width: 768px) 33vw, 100vw"
                     alt="{{ col.title | escape }}" loading="lazy">
              {% elsif col.products.first.featured_image %}
                <img src="{{ col.products.first.featured_image | img_url: '600x400' }}"
                     alt="{{ col.title | escape }}" loading="lazy">
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'collection-card__image-placeholder' }}
              {% endif %}
              <div class="collection-card__overlay"></div>
            </div>
            <div class="collection-card__content">
              <h3 class="collection-card__title">{{ block.settings.title | default: col.title }}</h3>
              <span class="collection-card__count">{{ col.all_products_count }} {{ col.all_products_count | pluralize: 'product', 'products' }}</span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.show_view_all %}
      <div class="section__footer text-center mt-xl">
        <a href="/collections" class="btn btn--outline">View All Collections</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "Browse By Category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop Collections" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show “View all collections” button", "default": true }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Override title" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "category": "Homepage",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
