{% comment %} Image-and-text split feature block. {% endcomment %}

<section class="feature-section" aria-labelledby="feature-heading-{{ section.id }}">
  <div class="container">
    <div class="feature-section__grid {% if section.settings.image_position == 'right' %}feature-section__grid--reverse{% endif %}">
      <div class="feature-section__image">
        {% if section.settings.image %}
          <img
            src="{{ section.settings.image | img_url: '800x600' }}"
            srcset="{{ section.settings.image | img_url: '400x300' }} 400w,
                    {{ section.settings.image | img_url: '800x600' }} 800w,
                    {{ section.settings.image | img_url: '1200x900' }} 1200w"
            sizes="(min-width: 1024px) 50vw, 100vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            loading="lazy">
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'feature-section__image-placeholder' }}
        {% endif %}
      </div>
      <div class="feature-section__content">
        {% if section.settings.overline != blank %}
          <span class="section__overline section__overline--left">{{ section.settings.overline }}</span>
        {% endif %}
        <h2 class="feature-section__title h2" id="feature-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
        {% if section.settings.text != blank %}
          <div class="feature-section__text rte">{{ section.settings.text }}</div>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature split",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image position",
      "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "text", "id": "overline", "label": "Overline", "default": "New Arrivals" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Discover Our Latest Collection" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Explore our newest additions, carefully curated to bring you the latest trends and timeless classics.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop New Arrivals" },
    { "type": "url", "id": "button_url", "label": "Button link" }
  ],
  "presets": [
    { "name": "Feature split", "category": "Homepage" }
  ]
}
{% endschema %}
