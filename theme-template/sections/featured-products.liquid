{% comment %} Featured product carousel with merchant-picked collection. {% endcomment %}

<section class="section" id="featured-products-{{ section.id }}" aria-labelledby="featured-heading-{{ section.id }}">
  <div class="container">
    <div class="section__header">
      {% if section.settings.overline != blank %}
        <span class="section__overline">{{ section.settings.overline }}</span>
      {% endif %}
      <h2 class="section__title h2" id="featured-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {% if section.settings.description != blank %}
        <p class="section__description">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    {% assign featured = collections[section.settings.collection] %}
    {% if featured == blank or featured.products.size == 0 %}
      {% assign featured = collections.all %}
    {% endif %}

    <div class="product-carousel" id="ProductCarousel-{{ section.id }}">
      <div class="product-carousel__wrapper">
        <div class="product-carousel__track">
          {% if featured.products.size > 0 %}
            {% for product in featured.products limit: section.settings.product_limit %}
              <div class="product-carousel__slide">
                {% render 'product-card', product: product %}
              </div>
            {% endfor %}
          {% else %}
            {% for i in (1..4) %}
              <div class="product-carousel__slide">
                <div class="pcard pcard--placeholder">
                  <div class="pcard__media">
                    {{ 'product-' | append: i | placeholder_svg_tag: 'pcard__placeholder-svg' }}
                  </div>
                  <div class="pcard__body">
                    <p class="pcard__title">Your product name</p>
                    <p class="pcard__price">$0.00</p>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      {% if section.settings.show_controls %}
        <div class="product-carousel__controls">
          <button type="button" class="product-carousel__btn product-carousel__btn--prev" aria-label="Previous products">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15,18 9,12 15,6"/></svg>
          </button>
          <div class="product-carousel__dots" id="CarouselDots-{{ section.id }}"></div>
          <button type="button" class="product-carousel__btn product-carousel__btn--next" aria-label="Next products">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9,6 15,12 9,18"/></svg>
          </button>
        </div>
      {% endif %}
    </div>

    {% if section.settings.show_view_all %}
      <div class="section__footer text-center mt-xl">
        <a href="{{ featured.url | default: '/collections/all' }}" class="btn btn--outline">{{ section.settings.view_all_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function() {
    var carousel = document.getElementById('ProductCarousel-{{ section.id }}');
    if (!carousel) return;
    var track = carousel.querySelector('.product-carousel__track');
    var slides = carousel.querySelectorAll('.product-carousel__slide');
    var prevBtn = carousel.querySelector('.product-carousel__btn--prev');
    var nextBtn = carousel.querySelector('.product-carousel__btn--next');
    var dotsContainer = document.getElementById('CarouselDots-{{ section.id }}');
    if (!track || slides.length === 0) return;

    var currentIndex = 0;
    function getSlidesPerView() {
      if (window.innerWidth >= 1024) return 4;
      if (window.innerWidth >= 768) return 3;
      return 2;
    }
    var slidesPerView = getSlidesPerView();
    var maxIndex = Math.max(0, slides.length - slidesPerView);

    function createDots() {
      if (!dotsContainer) return;
      dotsContainer.innerHTML = '';
      var count = Math.ceil(slides.length / slidesPerView);
      for (var i = 0; i < count; i++) {
        var dot = document.createElement('button');
        dot.className = 'product-carousel__dot' + (i === 0 ? ' product-carousel__dot--active' : '');
        dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        (function(idx){ dot.addEventListener('click', function(){ goTo(idx * slidesPerView); }); })(i);
        dotsContainer.appendChild(dot);
      }
    }
    function updateDots() {
      if (!dotsContainer) return;
      var active = Math.floor(currentIndex / slidesPerView);
      dotsContainer.querySelectorAll('.product-carousel__dot').forEach(function(d, i){
        d.classList.toggle('product-carousel__dot--active', i === active);
      });
    }
    function update() {
      var w = slides[0].offsetWidth + 24;
      track.style.transform = 'translateX(-' + (currentIndex * w) + 'px)';
      if (prevBtn) prevBtn.disabled = currentIndex === 0;
      if (nextBtn) nextBtn.disabled = currentIndex >= maxIndex;
      updateDots();
    }
    function goTo(i) { currentIndex = Math.max(0, Math.min(i, maxIndex)); update(); }
    if (prevBtn) prevBtn.addEventListener('click', function(){ goTo(currentIndex - slidesPerView); });
    if (nextBtn) nextBtn.addEventListener('click', function(){ goTo(currentIndex + slidesPerView); });

    var tid;
    window.addEventListener('resize', function() {
      clearTimeout(tid);
      tid = setTimeout(function() {
        var n = getSlidesPerView();
        if (n !== slidesPerView) {
          slidesPerView = n;
          maxIndex = Math.max(0, slides.length - slidesPerView);
          currentIndex = Math.min(currentIndex, maxIndex);
          createDots();
          update();
        }
      }, 200);
    });
    createDots();
    update();
  })();
</script>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "Curated Selection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Products" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Hand-picked items that showcase our commitment to quality and design." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 4, "max": 24, "step": 2, "default": 12 },
    { "type": "checkbox", "id": "show_controls", "label": "Show navigation arrows & dots", "default": true },
    { "type": "checkbox", "id": "show_view_all", "label": "Show “View all” button", "default": true },
    { "type": "text", "id": "view_all_label", "label": "“View all” label", "default": "View All Products" }
  ],
  "presets": [
    { "name": "Featured products", "category": "Homepage" }
  ]
}
{% endschema %}
