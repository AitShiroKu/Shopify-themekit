{% comment %} Hero banner with editable heading, subheading and product search. {% endcomment %}

<section class="hero hero--full" aria-labelledby="hero-heading-{{ section.id }}">
  {% if section.settings.background_image %}
    <div class="hero__background">
      <img
        src="{{ section.settings.background_image | img_url: '2000x' }}"
        srcset="{{ section.settings.background_image | img_url: '800x' }} 800w,
                {{ section.settings.background_image | img_url: '1200x' }} 1200w,
                {{ section.settings.background_image | img_url: '1800x' }} 1800w,
                {{ section.settings.background_image | img_url: '2400x' }} 2400w"
        sizes="100vw"
        alt="{{ section.settings.background_image.alt | default: section.settings.heading | escape }}"
        loading="eager">
    </div>
  {% endif %}
  <div class="hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>
  <div class="hero__content">
    {% if section.settings.overline != blank %}
      <span class="hero__overline">{{ section.settings.overline }}</span>
    {% endif %}
    <h1 class="hero__title" id="hero-heading-{{ section.id }}">
      {{ section.settings.heading | default: shop.name }}
    </h1>
    {% if section.settings.description != blank %}
      <p class="hero__description">{{ section.settings.description }}</p>
    {% endif %}

    <form action="{{ routes.search_url }}" method="get" role="search" class="hero__search" aria-label="Search products">
      <input type="hidden" name="type" value="product">
      <input type="hidden" name="options[prefix]" value="last">
      <svg class="hero__search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/>
        <line x1="20" y1="20" x2="16.65" y2="16.65"/>
      </svg>
      <input
        type="search"
        name="q"
        class="hero__search-input"
        placeholder="{{ section.settings.search_placeholder }}"
        aria-label="Search products"
        autocomplete="off">
      <button type="submit" class="hero__search-submit">
        {{ section.settings.search_button_label }}
        <span aria-hidden="true">→</span>
      </button>
    </form>
  </div>

  {% if section.settings.show_scroll_hint %}
    <a href="#featured-products" class="hero__scroll" aria-label="Scroll down to featured products">
      <span class="hero__scroll-label">{{ section.settings.scroll_hint_label }}</span>
      <span class="hero__scroll-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </a>
  {% endif %}
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 40 },
    { "type": "text", "id": "overline", "label": "Overline", "default": "Welcome to" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "StellarLight Magic" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Discover premium products crafted with excellence. Experience the perfect blend of quality and style." },
    { "type": "header", "content": "Search" },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "What are you looking for today?" },
    { "type": "text", "id": "search_button_label", "label": "Search button label", "default": "Search" },
    { "type": "header", "content": "Scroll hint" },
    { "type": "checkbox", "id": "show_scroll_hint", "label": "Show scroll-down hint", "default": true },
    { "type": "text", "id": "scroll_hint_label", "label": "Scroll hint label", "default": "Scroll to explore" }
  ],
  "presets": [
    { "name": "Hero", "category": "Homepage" }
  ]
}
{% endschema %}
