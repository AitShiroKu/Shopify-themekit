{% comment %} Instagram-style feed grid — blocks hold image + URL. {% endcomment %}

<section class="section section--compact" aria-labelledby="social-heading-{{ section.id }}">
  <div class="container">
    <div class="section__header">
      {% if section.settings.overline != blank %}
        <span class="section__overline">{{ section.settings.overline }}</span>
      {% endif %}
      <h2 class="section__title h2" id="social-heading-{{ section.id }}">
        {{ section.settings.heading | default: '@' | append: shop.name | handle }}
      </h2>
      {% if section.settings.description != blank %}
        <p class="section__description">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <div class="social-grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="social-grid__item" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
          {% else %}
            <div class="social-grid__item" {{ block.shopify_attributes }}>
          {% endif %}
            {% if block.settings.image %}
              <img src="{{ block.settings.image | img_url: '400x400' }}" alt="" loading="lazy">
            {% else %}
              <div class="social-grid__placeholder">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </div>
            {% endif %}
          {% if block.settings.link != blank %}</a>{% else %}</div>{% endif %}
        {% endfor %}
      {% else %}
        {% for i in (1..6) %}
          <div class="social-grid__item">
            <div class="social-grid__placeholder">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              </svg>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social feed",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "Follow Us" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "description", "label": "Description", "default": "Tag us to be featured" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    { "name": "Social feed", "category": "Homepage" }
  ]
}
{% endschema %}
