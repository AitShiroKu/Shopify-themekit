{% comment %} Value proposition grid — uses blocks so merchants can add/remove cards. {% endcomment %}

<section class="section section--alt" aria-labelledby="values-heading-{{ section.id }}">
  <div class="container">
    <div class="section__header">
      {% if section.settings.overline != blank %}
        <span class="section__overline">{{ section.settings.overline }}</span>
      {% endif %}
      <h2 class="section__title h2" id="values-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
    </div>

    <div class="value-grid">
      {% for block in section.blocks %}
        <div class="value-card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="value-card__icon">
              {{ block.settings.icon }}
            </div>
          {% endif %}
          <h3 class="value-card__title">{{ block.settings.title }}</h3>
          <p class="value-card__text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value propositions",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "Why Choose Us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The StellarLight Difference" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value card",
      "settings": [
        { "type": "html", "id": "icon", "label": "Icon (SVG)", "default": "<svg width='40' height='40' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'><path d='M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z'/><polyline points='3.27,6.96 12,12.01 20.73,6.96'/><line x1='12' y1='22.08' x2='12' y2='12'/></svg>" },
        { "type": "text", "id": "title", "label": "Title", "default": "Premium Quality" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Every product is carefully selected to meet our rigorous quality standards." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value propositions",
      "category": "Homepage",
      "blocks": [
        { "type": "value", "settings": { "title": "Premium Quality", "text": "Every product is carefully selected to meet our rigorous quality standards." } },
        { "type": "value", "settings": { "title": "Fast Shipping", "text": "Free shipping on orders over $50. Delivered within 3-5 days." } },
        { "type": "value", "settings": { "title": "Secure Checkout", "text": "Shop with confidence. Your payment information is always protected." } },
        { "type": "value", "settings": { "title": "24/7 Support", "text": "Our dedicated team is here to help you with any questions." } }
      ]
    }
  ]
}
{% endschema %}
